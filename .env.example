# Copy this file to .env and fill in your actual values.
# .env is gitignored — never commit secrets.

# OpenAI API key
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXX...

# Optional — OpenAI model selection
# Defaults to gpt-4.1 if unset. Alternatives: gpt-4o, gpt-4o-mini (cheaper),
# o3-mini (reasoning), gpt-5 (if available on your account).
OPENAI_MODEL=gpt-4.1

# Optional — embedding model for RAG (HuggingFace, runs locally)
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Optional — ChromaDB persist path
CHROMA_DB_PATH=./chroma_db

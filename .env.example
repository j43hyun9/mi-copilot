# Copy this file to .env and fill in your actual values.
# .env is gitignored — never commit secrets.

# Claude API key (Anthropic)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXX...

# Optional — Claude model selection
# Defaults to claude-opus-4-7 if unset (longest context, strongest reasoning)
# Alternatives: claude-sonnet-4-6 (faster, cheaper), claude-haiku-4-5-20251001 (fastest)
ANTHROPIC_MODEL=claude-opus-4-7

# Optional — embedding model for RAG (HuggingFace, runs locally)
# Default is multilingual model strong on Korean + English (MI papers are English, queries may be Korean)
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Optional — ChromaDB persist path
CHROMA_DB_PATH=./chroma_db
